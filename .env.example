# Database (Turso / libSQL, local embedded file). Optional — defaults to ./data.db.
# This is a LOCAL file, not Turso Cloud.
TURSO_PATH=./data.db

# Authentication
JWT_SECRET=change-this-to-a-random-secret

# First-admin bootstrap (only used on a FRESH database with no players).
# Set both to seed your first admin account automatically — recommended for any
# persistent/production deployment. If you leave these unset, a fresh database
# generates an 'admin' account with a random password printed to the server logs
# (handy for ephemeral `docker run` test instances).
# BOOTSTRAP_ADMIN_USERNAME=admin
# BOOTSTRAP_ADMIN_PASSWORD=change-this-to-a-strong-password

# Optional: Emergency access bypass (if locked out by IP access controls)
# EMERGENCY_ACCESS_TOKEN=your_emergency_token_here

# Reverse-proxy / TLS settings. Only relevant when the server runs behind an
# HTTPS-terminating reverse proxy (nginx, Traefik, Caddy...). Leave unset for a
# plain-HTTP deployment.
#
# TRUST_PROXY=true      # Trust the X-Forwarded-For header for client-IP
#                       # detection. REQUIRED behind a proxy for IP access
#                       # control (allow/block lists) and logging to see the
#                       # real client IP instead of the proxy's. Default: false.
# TRUST_PROXY_TLS=true  # Emit the HSTS (Strict-Transport-Security) header. Set
#                       # ONLY when a TLS proxy fronts the app; the container
#                       # itself serves plain HTTP, so HSTS is off by default to
#                       # avoid forcing browsers to HTTPS against a non-TLS
#                       # server. Default: false.
