# Database (Turso / libSQL, local embedded file). Optional — defaults to ./data.db.
# This is a LOCAL file, not Turso Cloud.
TURSO_PATH=./data.db

# Authentication
JWT_SECRET=change-this-to-a-random-secret

# Optional: Emergency access bypass (if locked out by IP access controls)
# EMERGENCY_ACCESS_TOKEN=your_emergency_token_here
