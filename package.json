{
  "name": "kingdoms-of-avarice",
  "version": "1.0.0",
  "private": true,
  "description": "A web-based MUD game inspired by MajorMUD",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "npm run dev --workspace=@koa/client",
    "dev:server": "npm run dev --workspace=@koa/server",
    "build": "npm run build --workspaces",
    "build:shared": "npm run build --workspace=@koa/shared",
    "build:client": "npm run build --workspace=@koa/client",
    "build:server": "npm run build --workspace=@koa/server",
    "migrate": "npm run migrate --workspace=@koa/server",
    "seed:arindale": "npx tsx packages/server/src/db/seed-arindale.ts",
    "map:arindale": "npx tsx packages/server/src/db/arindale/generate-map.ts",
    "data:export": "npx tsx packages/server/src/db/data-export.ts",
    "data:import": "npx tsx packages/server/src/db/data-import.ts",
    "setup": "npm install && npm run build:shared && npm run migrate && npm run data:import",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.3.3",
    "vitest": "^4.0.17"
  }
}
